<!--0-->  <xs:element name="fixedDateRange" type="fixedDateRangeType" minOccurs="1" maxOccurs="1"/>
<!--1-->  <xs:element name="weatherWarningMessage" type="weatherWarningMessageType" minOccurs="0" maxOccurs="1"/>
<!--2-->  <xs:element name="issueDate" type="issueDateType" minOccurs="1" maxOccurs="1"/>
<!--3-->  <xs:element name="issueTime" type="issueTimeType" minOccurs="0" maxOccurs="1"/>
<!--4-->  <xs:element name="weatherWarningNumber" type="weatherWarningNumberType" minOccurs="1" maxOccurs="1"/>
<!--5-->  <xs:element name="cancellationDate" type="cancellationDateType" minOccurs="1" maxOccurs="1"/>
<!--6-->  <xs:element name="nextUpdateDateTime" type="nextUpdateDateTimeType" minOccurs="0" maxOccurs="1"/>
<!--7-->  <xs:element name="interoperabilityIdentifier" type="interoperabilityIdentifierType" minOccurs="0" maxOccurs="1"/>
<!--8-->  <xs:element name="dataProviderInformation" type="gml:ReferenceType" minOccurs="0" maxOccurs="1"/>
 </xs:sequence>
            </xs:extension>        </xs:complexContent>
    </xs:complexType>
    <xs:complexType name="IceAccretionWarningType" abstract="false">
        <xs:annotation>
            <xs:documentation>A product issued by a national authority when ice accumulation rates pose a hazard to vessels.</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="WeatherWarningType">
                <xs:sequence>
                    <!-- attributes -->
<!--0-->  <xs:element name="iceAccretionRate" type="iceAccretionRateType" minOccurs="1" maxOccurs="1"/>
<!--1-->  <xs:element name="sourceOfIcing" type="sourceOfIcingType" minOccurs="0" maxOccurs="1"/>
                    <xs:element name="geometry" maxOccurs="unbounded">
                        <xs:complexType>
                            <xs:choice>
                                <xs:element ref="S100:surfaceProperty"/>
                            </xs:choice>
                        </xs:complexType>
                    </xs:element>
 </xs:sequence>
            </xs:extension>        </xs:complexContent>
    </xs:complexType>
    <xs:complexType name="RestrictedVisibilityWarningType" abstract="false">
        <xs:annotation>
            <xs:documentation>A product issued by a national authority when horizontal visibility is degraded to less than 0.5 nautical miles by fog, smoke, dust, haze, heavy precipitation, or any other phenomena.</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="WeatherWarningType">
                <xs:sequence>
                    <!-- attributes -->
                    <xs:element name="geometry" maxOccurs="unbounded">
                        <xs:complexType>
                            <xs:choice>
                                <xs:element ref="S100:surfaceProperty"/>
                            </xs:choice>
                        </xs:complexType>
                    </xs:element>
 </xs:sequence>
            </xs:extension>        </xs:complexContent>
    </xs:complexType>
    <xs:complexType name="SignificantWaveHeightWarningType" abstract="false">
        <xs:annotation>
            <xs:documentation>A product issued by a national authority when sea state conditions pose a hazard or are life-threatening.</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="WeatherWarningType">
                <xs:sequence>
                    <!-- attributes -->
