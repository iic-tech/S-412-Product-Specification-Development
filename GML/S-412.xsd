<!--0-->  <xs:element name="windWarningThreshold" type="windWarningThresholdType" minOccurs="1" maxOccurs="1"/>
<!--1-->  <xs:element name="beaufortForce" type="beaufortForceType" minOccurs="0" maxOccurs="1"/>
<!--2-->  <xs:element name="maximumWindSpeed" type="maximumWindSpeedType" minOccurs="1" maxOccurs="1"/>
                    <xs:element name="geometry" maxOccurs="unbounded">
                        <xs:complexType>
                            <xs:choice>
                                <xs:element ref="S100:surfaceProperty"/>
                            </xs:choice>
                        </xs:complexType>
                    </xs:element>
 </xs:sequence>
            </xs:extension>        </xs:complexContent>
    </xs:complexType>
    <xs:element name="IceAccretionWarning" type="IceAccretionWarningType"/>
    <xs:element name="RestrictedVisibilityWarning" type="RestrictedVisibilityWarningType"/>
    <xs:element name="SignificantWaveHeightWarning" type="SignificantWaveHeightWarningType"/>
    <xs:element name="ThunderstormWarning" type="ThunderstormWarningType"/>
    <xs:element name="WindWarning" type="WindWarningType"/>
    <xs:group name="MemberObjects">
        <xs:annotation>
            <xs:documentation>group of informtion, feature and meta objects, all GML members</xs:documentation>
        </xs:annotation>
        <xs:choice>
<xs:element ref="IceAccretionWarning"/><xs:element ref="RestrictedVisibilityWarning"/><xs:element ref="SignificantWaveHeightWarning"/><xs:element ref="ThunderstormWarning"/><xs:element ref="WindWarning"/><xs:element ref="DataProvider"/>        </xs:choice>
    </xs:group>
    <xs:complexType name="ThisDatasetType">
