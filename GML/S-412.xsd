        <xs:annotation>
            <xs:documentation>The name of the Nation and National Meteorological and Hydrological Service (NMHS) or National Authority that prepared the warning and transferred it to the relevant Issuing Service for broadcast if not the same.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->            <xs:element name="issuingServiceName" type="issuingServiceNameType" minOccurs="1" maxOccurs="1"/>            <xs:element name="countryName" type="countryNameType" minOccurs="0" maxOccurs="1"/>        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="weatherWarningMessageType">
        <xs:annotation>
            <xs:documentation>Text message associated with a weather warning polygon.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->            <xs:element name="information" type="informationType" minOccurs="1" maxOccurs="unbounded"/>        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="DataProviderType" abstract="false">
        <xs:annotation>
            <xs:documentation>The national authority providing a data in an official capacity.</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="S100:AbstractInformationType">
                <xs:sequence>
                    <!-- attributes -->
<!--0-->     <xs:element name="issuingService" type="issuingServiceType" minOccurs="1" maxOccurs="1"/>
<!--1-->     <xs:element name="contactInformation" type="contactInformationType" minOccurs="1" maxOccurs="1"/>
<!--2-->     <xs:element name="preparationService" type="preparationServiceType" minOccurs="1" maxOccurs="1"/>
 </xs:sequence>
            </xs:extension>        </xs:complexContent>
    </xs:complexType>
    <xs:element name="DataProvider" type="DataProviderType"/>
    <xs:complexType name="WeatherWarningType" abstract="true">
        <xs:annotation>
            <xs:documentation>A product issued by a national authority when a specific weather scenario or event threatens people or property meets criteria defined by WMO (WMO No. 558 and No. 471) or by a national authority where applicable.</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="S100:AbstractFeatureType">
