                    <xs:element name="geometry" maxOccurs="unbounded">
                        <xs:complexType>
                            <xs:choice>
                                <xs:element ref="S100:surfaceProperty"/>
                            </xs:choice>
                        </xs:complexType>
                    </xs:element>
 </xs:sequence>
            </xs:extension>        </xs:complexContent>
    </xs:complexType>
    <xs:complexType name="ThunderstormWarningType" abstract="false">
        <xs:annotation>
            <xs:documentation>A product issued by a national authority when an area of thunderstorms or squalls poses a hazard. Conditions could include strong winds, locally higher waves, potentially heavy precipitation, hail, and dangerous lightning strikes.</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="WeatherWarningType">
                <xs:sequence>
                    <!-- attributes -->
                    <xs:element name="geometry" maxOccurs="unbounded">
                        <xs:complexType>
                            <xs:choice>
                                <xs:element ref="S100:surfaceProperty"/>
                            </xs:choice>
                        </xs:complexType>
                    </xs:element>
 </xs:sequence>
            </xs:extension>        </xs:complexContent>
    </xs:complexType>
    <xs:complexType name="WindWarningType" abstract="false">
        <xs:annotation>
            <xs:documentation>A product issued by a national authority when high wind speeds pose a hazard or are life-threatening.</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="WeatherWarningType">
                <xs:sequence>
